# Supabase — from Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the client. From Supabase Dashboard →
# Project Settings → API → service_role key. Required for:
#   - seeding/managing users (admin page)
#   - the "Delete all data except admin" wipe
#   - the one-time admin bootstrap script (scripts/seed-admin.mjs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# One-time bootstrap of the initial admin (used by scripts/seed-admin.mjs).
# After first login the admin is forced to change this password.
SEED_ADMIN_EMAIL=ihsahn@me.com
SEED_ADMIN_PASSWORD=change-me-on-first-login
